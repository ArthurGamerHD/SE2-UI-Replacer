<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:CompileBindings="False">
    <Style Selector="Grid#StyleRoot">
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        <Setter Property="RenderTransform">
            <TransformGroup>
                <ScaleTransform ScaleX="{DynamicResource UIRevamp_HudWobbleZ}"
                                ScaleY="{DynamicResource UIRevamp_HudWobbleZ}" />
                <TranslateTransform X="{DynamicResource UIRevamp_HudWobbleX}"
                                    Y="{DynamicResource UIRevamp_HudWobbleY}" />
            </TransformGroup>
        </Setter>
    </Style>
</Styles>
