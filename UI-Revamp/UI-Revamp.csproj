            <HintPath>$(SE2Game2Path)VRage.UI.dll</HintPath>
        </Reference>
        <Reference Include="VRage.UI.Shared">
            <HintPath>$(SE2Game2Path)VRage.UI.Shared.dll</HintPath>
        </Reference>
        <Reference Include="VRage.Voxels">
            <HintPath>$(SE2Game2Path)VRage.Voxels.dll</HintPath>
        </Reference>
        <Reference Include="VRage.Voxels.Client">
            <HintPath>$(SE2Game2Path)VRage.Voxels.Client.dll</HintPath>
        </Reference>
        <Reference Include="VRage.Voxels.Editor">
            <HintPath>$(SE2Game2Path)VRage.Voxels.Editor.dll</HintPath>
        </Reference>
        <Reference Include="VRage.Water">
            <HintPath>$(SE2Game2Path)VRage.Water.dll</HintPath>
        </Reference>
        <Reference Include="VRage.Water.Client">
            <HintPath>$(SE2Game2Path)VRage.Water.Client.dll</HintPath>
        </Reference>
    </ItemGroup>

    <Target Name="CopyDebugNativeDevToolsDesktopAssemblies" BeforeTargets="CopyDll" Condition="'$(IsDesign)' != 'true' and '$(Configuration)' == 'Debug'">
        <ItemGroup>
            <NativeDevToolsDesktopAssembly Include="$(NuGetPackageRoot)avalonia.win32/11.0.10/lib/net6.0/Avalonia.Win32.dll" />
            <NativeDevToolsDesktopAssembly Include="$(NuGetPackageRoot)avalonia/11.0.10/lib/net6.0/Avalonia.MicroCom.dll" />
            <NativeDevToolsDesktopAssembly Include="$(NuGetPackageRoot)avalonia/11.0.10/lib/net6.0/Avalonia.Metal.dll" />
            <NativeDevToolsDesktopAssembly Include="$(NuGetPackageRoot)avalonia.skia/11.0.10/lib/net6.0/Avalonia.Skia.dll" />
            <NativeDevToolsDesktopAssembly Include="$(NuGetPackageRoot)avalonia/11.0.10/lib/net6.0/Avalonia.OpenGL.dll" />
            <NativeDevToolsDesktopAssembly Include="$(NuGetPackageRoot)skiasharp/2.88.7/lib/net6.0/SkiaSharp.dll" />
            <NativeDevToolsDesktopAssembly Include="$(NuGetPackageRoot)skiasharp.nativeassets.win32/2.88.7/runtimes/win-x64/native/libSkiaSharp.dll" />
        </ItemGroup>

        <Copy
                SourceFiles="@(NativeDevToolsDesktopAssembly)"
                DestinationFolder="$(OutDir)"
                SkipUnchangedFiles="true" />
    </Target>

    <Target Name="PatchDebugNativeDevToolsSkiaAbi" AfterTargets="CopyDebugNativeDevToolsDesktopAssemblies" BeforeTargets="CopyDll" Condition="'$(IsDesign)' != 'true' and '$(Configuration)' == 'Debug'">
        <Exec Command="dotnet run --project &quot;$(MSBuildThisFileDirectory)..\Tools\AvaloniaSkiaKeenAbiPatch\AvaloniaSkiaKeenAbiPatch.csproj&quot; -- &quot;$(TargetDir)Avalonia.Skia.dll&quot; &quot;$(SE2Game2Path)Avalonia.Base.dll&quot;" />
    </Target>

    <Target Name="CopyDll" AfterTargets="PostBuildEvent" Condition="'$(IsDesign)' != 'true'">
        <PropertyGroup>
            <SourceDll>$(TargetDir)$(TargetName).dll</SourceDll>
            <DestinationFolder>$(SE2PluginsPath)</DestinationFolder>
        </PropertyGroup>
        <ItemGroup>
            <PluginCopyFile Include="$(SourceDll)" />
            <PluginCopyFile Include="$(TargetDir)Avalonia.Win32.dll" Condition="'$(Configuration)' == 'Debug'" />
            <PluginCopyFile Include="$(TargetDir)Avalonia.MicroCom.dll" Condition="'$(Configuration)' == 'Debug'" />
            <PluginCopyFile Include="$(TargetDir)Avalonia.Metal.dll" Condition="'$(Configuration)' == 'Debug'" />
            <PluginCopyFile Include="$(TargetDir)Avalonia.Skia.dll" Condition="'$(Configuration)' == 'Debug'" />
            <PluginCopyFile Include="$(TargetDir)Avalonia.OpenGL.dll" Condition="'$(Configuration)' == 'Debug'" />
            <PluginCopyFile Include="$(TargetDir)SkiaSharp.dll" Condition="'$(Configuration)' == 'Debug'" />
            <PluginCopyFile Include="$(TargetDir)libSkiaSharp.dll" Condition="'$(Configuration)' == 'Debug'" />
        </ItemGroup>

        <Copy
                SourceFiles="@(PluginCopyFile)"
                DestinationFolder="$(DestinationFolder)"
                SkipUnchangedFiles="false" />
    </Target>

    <Target Name="ExportPluginDll" AfterTargets="Build" Condition="'$(IsDesign)' != 'true' and '$(Configuration)' == 'ExportPlugin'">
        <ItemGroup>
            <PluginExportFile Include="$(TargetDir)$(TargetName).dll" />
            <PluginExportFile Include="$(SE2Game2Path)0Harmony.dll" />
            <SE2Executable Include="$(SE2Game2Path)SpaceEngineers2.dll" />
        </ItemGroup>

        <GetAssemblyIdentity AssemblyFiles="@(SE2Executable)">
            <Output TaskParameter="Assemblies" ItemName="SE2ExecutableAssembly" />
        </GetAssemblyIdentity>

        <PropertyGroup>
            <SE2Version>%(SE2ExecutableAssembly.Version)</SE2Version>
            <PluginZipStagingDir>$(TargetDir)zip\$(SE2PluginName)\</PluginZipStagingDir>
            <PluginZipPath>$(TargetDir)$(SE2PluginName)-$(Version)-Se2-$(SE2Version).zip</PluginZipPath>
        </PropertyGroup>
        <ItemGroup>
            <ExistingPluginZip Include="$(TargetDir)$(SE2PluginName)-*.zip" />
        </ItemGroup>

        <MakeDir Directories="$(SE2PluginsPath)" />
        <Copy
                SourceFiles="@(PluginExportFile)"
                DestinationFolder="$(SE2PluginsPath)"
                SkipUnchangedFiles="false" />

        <RemoveDir Directories="$(PluginZipStagingDir)" />
        <MakeDir Directories="$(PluginZipStagingDir)" />
        <Copy
                SourceFiles="@(PluginExportFile)"
                DestinationFolder="$(PluginZipStagingDir)"
                SkipUnchangedFiles="false" />
        <Delete Files="@(ExistingPluginZip)" />
        <ZipDirectory
                SourceDirectory="$(PluginZipStagingDir)"
                DestinationFile="$(PluginZipPath)"
                Overwrite="true" />
    </Target>
</Project>
