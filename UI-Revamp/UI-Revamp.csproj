<Project Sdk="Microsoft.NET.Sdk">
    <Import Project="$(MSBuildThisFileDirectory)../Directory.Build.local.props" Condition="Exists('$(MSBuildThisFileDirectory)../Directory.Build.local.props')" />

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <Nullable>enable</Nullable>
        <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
        <ApplicationManifest>app.manifest</ApplicationManifest>
        <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
        <RootNamespace>UI_Revamp</RootNamespace>
        <Configurations>Debug;Release;ExportPlugin;Preview</Configurations>
        <Platforms>AnyCPU</Platforms>
        <SE2PluginName>UI-Revamp</SE2PluginName>
        <Version>1.0.0</Version>
        <SE2InstallPath Condition="'$(SE2InstallPath)' == ''">C:\Program Files (x86)\Steam\steamapps\common\SpaceEngineers2\</SE2InstallPath>
        <SE2Game2Path Condition="'$(SE2Game2Path)' == ''">$(SE2InstallPath)Game2\</SE2Game2Path>
        <SE2PluginsPath Condition="'$(SE2PluginsPath)' == ''">$(SE2InstallPath)SpaceEngineers2\Plugins\</SE2PluginsPath>
        <IsDesign Condition="'$(IsDesign)' == '' and '$(Configuration)' == 'Preview'">true</IsDesign>
        <RuntimeIdentifier Condition="'$(Configuration)' == 'Preview' and '$(RuntimeIdentifier)' == ''">linux-x64</RuntimeIdentifier>
        <SelfContained Condition="'$(Configuration)' == 'Preview'">false</SelfContained>
        <DefineConstants Condition="'$(Configuration)' == 'Preview'">$(DefineConstants);PREVIEW</DefineConstants>
        <DefineConstants Condition="'$(IsDesign)' == 'true'">$(DefineConstants);IS_DESIGN</DefineConstants>
        <GenerateRuntimeConfigurationFiles Condition="'$(IsDesign)' == 'true'">true</GenerateRuntimeConfigurationFiles>
        <CopyLocalLockFileAssemblies Condition="'$(IsDesign)' == 'true'">true</CopyLocalLockFileAssemblies>
    </PropertyGroup>

    <ItemGroup>
        <AvaloniaResource Include="Assets\**" Exclude="Assets\Preview\**"/>
        <AvaloniaResource Include="Assets\Preview\**" Condition="'$(IsDesign)' == 'true'"/>
    </ItemGroup>


    <ItemGroup>
        <!--Condition below is needed to remove Avalonia.Diagnostics package from build output in Release configuration.-->
        <PackageReference Include="Avalonia" Version="11.0.10" />
        <PackageReference Include="Avalonia.Desktop" Version="11.0.10" Condition="'$(Configuration)' == 'Debug' or '$(IsDesign)' == 'true'" />
        <PackageReference Include="SkiaSharp.NativeAssets.Win32" Version="2.88.7" Condition="'$(Configuration)' == 'Debug' and '$(IsDesign)' != 'true'" />
        <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.1"/>
        <PackageReference Include="Lib.Harmony" Version="2.3.6" />
    </ItemGroup>

    <ItemGroup Condition="'$(IsDesign)' == 'true'">
        <Compile Remove="**\*.cs" />
        <Compile Include="CurvedHud\ArtificialHorizon.cs" />
        <Compile Include="CurvedHud\Compass.cs" />
        <Compile Include="CurvedHud\HudPreviewUtility.cs" />
        <Compile Include="CurvedHud\HudPreviewViewModel.cs" />
        <Compile Include="CurvedHud\CurvedHudWindow.axaml.cs" />
        <Compile Include="Styles\CoreStyles.axaml.cs" />
        <AvaloniaXaml Remove="**\*.axaml" />
        <AvaloniaXaml Include="CurvedHud\CurvedHudWindow.axaml" />
        <AvaloniaXaml Include="Resources\**\*.axaml" />
        <AvaloniaXaml Include="Styles\CoreStyles.axaml" />
    </ItemGroup>

